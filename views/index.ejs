<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
        content="محتار تختار المدرس الصح؟ منصة المستر هي أول منصة مصرية لتقييم مدرسي الثانوية العامة والبكالوريا بناءً على تجارب وآراء الطلاب الحقيقية.">
    <title>منصة المستر التعليمية - الرئيسية</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet">

    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f8f9fa;
        }

        .hero-section {
            background: linear-gradient(135deg, #2980b9, #3498db);
            color: white;
            padding: 20px 0;
            border-radius: 0 0 24px 24px;
        }

        .feature-card {
            transition: transform 0.2s;
        }

        .feature-card:hover {
            transform: translateY(-5px);
        }
    </style>
    <meta name="google-site-verification" content="iqWzuJaYjfpulx8Ro3rh7smPdUHFHCbebM0jt8ieqxU" />

</head>
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-JY6XG2MXHM"></script>
<script>
    window.dataLayer = window.dataLayer || [];
    function gtag() { dataLayer.push(arguments); }
    gtag('js', new Date());

    gtag('config', 'G-JY6XG2MXHM');
</script>

<body dir="rtl">
    <%- include('partials/header') %>
        <div class="hero-section shadow-sm" style="padding: 0px 0; border-radius: 0 0 24px 24px;">
            <div class="container">
                <!-- تم تقليل الـ g-4 إلى g-2 لتقليل المسافات الداخلية بين العناصر أيضاً -->
                <div class="row justify-content-center align-items-center g-2 text-center">

                    <div class="col-lg-8 col-12 dir-rtl">
                        <!-- تقليل الـ mb-3 إلى mb-1 -->
                        <h1 class="display-5 fw-bold mb-1 text-center">منصة المستر التعليمية 🎓</h1>

                        <!-- تقليل الـ mb-4 إلى mb-2 لضغط النص -->
                        <p class="mb-2 text-white fs-5 fw-normal text-center" style="line-height: 1.6;">
                            محتار ومش عارف تختار المدرس الصح؟ 
                            <span class="fw-bold text-warning">المستر</span> هنا عشان يساعدك! <br>
                            أول منصة مصرية تتيح للطلاب تقييم المدرسين بكل صراحة، 
                            عشان تختار مدرسك الجاي بثقة وبناءً على تجارب حقيقية.
                        </p>

                        <!-- تقليل الـ mt-4 إلى mt-2 لرفع الزر للأعلى -->
                        <div class="mt-2 text-center">
                            <a href="/teachers" class="btn btn-warning btn-lg fs-5 fw-bold shadow px-4 py-2">
                                تصفح المدرسين و اضف تقييمك الآن 🔍
                            </a>
                        </div>
                    </div>

                </div>
            </div>
        </div>
        <div class="container mt-5 mb-4">
            <h2 class="text-center fw-bold text-dark position-relative pb-2">
                🏆 المدرسين الأعلى تقييماً على مستوى الجمهورية
            </h2>
            <p class="text-center text-muted">نخبة من أفضل معلمي الثانوية العامة والبكالوريا بناءً على اختيارات الطلاب
            </p>
        </div>

        <div class="container">
            <!-- row-cols-1 للموبايل و row-cols-md-2 ليعرض كارتين في السطر -->
            <div class="row row-cols-1 row-cols-md-2 g-4 justify-content-center">

                <% teachers.forEach(teacher=> { %>
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 bg-white p-4 teacher-card d-flex flex-column justify-content-between"
                            style="border-radius: 20px; min-height: 460px;">

                            <!-- الجزء العلوي: تم تكبير الصورة والاسم إلى الحد الأقصى المتناسق -->
                            <div class="text-center">
                                <!-- تكبير الصورة إلى 160px وزيادة سمك الإطار والظل -->
                                <div class="mb-3 position-relative d-inline-block">
                                    <img src="<%= teacher.photo_url %>"
                                        class="rounded-circle border border-4 border-white shadow animate-avatar"
                                        alt="<%= teacher.name %>"
                                        style="width: 160px; height: 160px; object-fit: cover;">
                                </div>

                                <!-- تكبير اسم المدرس إلى fs-2 وجعله عريضاً جداً fw-black -->
                                <h3 class="fw-black text-dark mb-2 fs-2" style="letter-spacing: -0.5px;">
                                    <%= teacher.name %>
                                </h3>

                                <span
                                    class="badge bg-success text-white px-3 py-1 rounded-pill fs-7 mb-3 d-inline-block">
                                    📚 <%= teacher.subject %>
                                </span>

                                <!-- التقييم الرقمي والنجوم -->
                                <div class="text-warning mb-1">
                                    <span class="fs-4 fw-bold">
                                        <%= teacher.avg_rating %>
                                    </span> ★
                                </div>
                                <small class="text-muted d-block mb-3">(متوسط <%= teacher.total_reviews %>
                                        تقييم)</small>
                            </div>

                            <!-- روابط التواصل الاجتماعي الخاصة بالمدرس -->
                            <div class="d-flex flex-wrap justify-content-center gap-2 mb-3">
                                <% if (teacher.facebook_url) { %>
                                    <a href="<%= teacher.facebook_url %>" target="_blank"
                                        class="btn btn-outline-primary btn-sm rounded-pill py-1 px-2 fs-7 fw-semibold">
                                        صفحة المدرس 🔗
                                    </a>
                                    <% } %>
                                        <% if (teacher.website_url) { %>
                                            <a href="<%= teacher.website_url %>" target="_blank"
                                                class="btn btn-outline-secondary btn-sm rounded-pill py-1 px-2 fs-7 fw-semibold">
                                                المنصة الخاصة 🌐
                                            </a>
                                            <% } %>
                                                <% if (teacher.youtube_url) { %>
                                                    <a href="<%= teacher.youtube_url %>" target="_blank"
                                                        class="btn btn-outline-danger btn-sm rounded-pill py-1 px-2 fs-7 fw-semibold d-inline-flex align-items-center gap-1">
                                                        قناة اليوتيوب 📺
                                                    </a>
                                                    <% } %>
                            </div>

                            <!-- زر عرض التقييمات أو صندوق إضافة التقييم السريع -->
                            <div class="border-top pt-3 text-center">
                                <a href="/teachers/<%= teacher.id %>"
                                    class="btn btn-primary btn-sm px-4 py-2 fw-semibold rounded-pill w-100 mb-2">
                                    👁️ عرض التقييمات والآراء بالتفصيل
                                </a>

                                <% if (typeof userSession !=='undefined' && userSession && userSession.userId) { %>
                                    <a href="/teachers/<%= teacher.id %>#review-section"
                                        class="text-secondary small d-block mt-1 fw-bold text-decoration-none">
                                        ✍️ أضف تقييمك السريع لهذا المدرس
                                    </a>
                                    <% } else { %>
                                        <button type="button"
                                            class="btn btn-outline-dark btn-sm fw-bold px-3 shadow-sm rounded-pill w-100"
                                            data-bs-toggle="modal" data-bs-target="#loginPromptModal">
                                            🔒 سجل دخولك لتقييم المدرس
                                        </button>
                                        <% } %>
                            </div>

                        </div>
                    </div>
                    <% }) %>

            </div>
        </div>
        <div class="container my-5">
            <h2 class="text-center fw-bold mb-5 text-dark">ليه تختار منصة المستر</h2>

            <div class="row g-4 text-center">
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm p-4 feature-card">
                        <div class="card-body">
                            <div class="display-4 text-primary mb-3">🎯</div>
                            <h4 class="card-title fw-bold mb-3">تحديد الهدف</h4>
                            <p class="card-text text-muted fs-bold fs-4">نساعد الطالب على اختيار المدرس الأنسب لطريقة
                                استيعابه لضمان أعلى الدرجات.</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm p-4 feature-card">
                        <div class="card-body">
                            <div class="display-4 text-success mb-3">⚡</div>
                            <h4 class="card-title fw-bold mb-3">سرعة الوصول</h4>
                            <p class="card-text text-muted fs-bold fs-4">البحث عن المدرسين والمواد يتم في أجزاء من
                                الثانية بفضل بنيتنا التحتية الذكية.</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm p-4 feature-card">
                        <div class="card-body">
                            <div class="display-4 text-warning mb-3">🔒</div>
                            <h4 class="card-title fw-bold mb-3">بيانات موثوقة</h4>
                            <p class="card-text text-muted fs-bold fs-4">يتم مراجعة وتقييم المدرسين بناءً على تجارب طلاب
                                حقيقيين وبدقة شديدة</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <%- include('partials/footer') %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
                integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
                crossorigin="anonymous"></script>
</body>

</html>