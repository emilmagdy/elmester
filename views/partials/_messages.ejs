<% if (success_msg && success_msg.length > 0) { %>
    <div class="alert alert-success alert-dismissible fade show rounded-0 shadow-sm small py-2 mb-4" role="alert">
        ✨ <%= success_msg %>
        <button type="button" class="btn-close py-2" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<% } %>

<% if (error_msg && error_msg.length > 0) { %>
    <div class="alert alert-danger alert-dismissible fade show rounded-0 shadow-sm small py-2 mb-4" role="alert">
        ⚠️ <%= error_msg %>
        <button type="button" class="btn-close py-2" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<% } %>