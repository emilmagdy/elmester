<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>منصة مستشارك - <%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; font-family: 'Segoe UI', Tahoma, sans-serif; }
        .error-card { border-right: 5px solid #dc3545 !important; } /* حافة حمراء تعبر عن الخطأ */
    </style>
</head>
<body>
<%- include('partials/header') %>

<div class="container my-5 py-5">
    <div class="row justify-content-center">
        <div class="col-md-7 text-center">
            <div class="card error-card shadow-sm border-0 bg-white p-5 rounded-0">
                <h1 class="display-1 fw-bold text-danger mb-3"><%= status %></h1>
                <h2 class="h4 fw-bold text-dark mb-3"><%= title %></h2>
                <p class="text-muted mb-4 fs-6"><%= message %></p>
                <div class="d-flex justify-content-center gap-2">
                    <a href="/teachers" class="btn btn-primary rounded-0 btn-sm px-4">🔍 تصفح المدرسين</a>
                    <a href="/" class="btn btn-outline-secondary rounded-0 btn-sm px-4">🏠 الرئيسية</a>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
</body>
</html>