<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>إنشاء حساب جديد | مستشارك</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Cairo', sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
        }
        .signup-container {
            max-width: 500px;
            width: 90%;
            margin: auto;
        }
        .card {
            border: none;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        }
        .card-header {
            background-color: transparent;
            border-bottom: none;
            padding-top: 30px;
        }
        .btn-primary {
            border-radius: 10px;
            padding: 12px;
            font-weight: 700;
            background-color: #0d6efd;
            border: none;
            transition: all 0.3s ease;
        }
        .btn-primary:hover {
            background-color: #0b5ed7;
            transform: translateY(-2px);
        }
        /* Custom adjustment for Bootstrap 5 Floating Labels in RTL mode */
        .form-floating > label {
            right: 0;
            left: auto;
            padding-right: 1.25rem;
        }
        .form-floating > .form-control:focus ~ label,
        .form-floating > .form-control:not(:placeholder-shown) ~ label,
        .form-floating > .form-select ~ label {
            transform: scale(.85) translateY(-0.5rem) translateX(-0.5rem);
        }
    </style>
</head>
<body>

<div class="signup-container">
    <div class="card p-4">
        <div class="card-header text-center">
            <h2 class="fw-bold text-primary">إنشاء حساب</h2>
            <p class="text-muted">انضم لزملائك في "مستشارك" التعليمي</p>
        </div>
        <div class="card-body">
            <form action="/register" method="POST" class="needs-validation" novalidate>
                
                <div class="form-floating mb-3">
                    <input type="text" class="form-control" id="name" name="name" placeholder="الاسم الكامل" required>
                    <label for="name">الاسم الكامل</label>
                    <div class="invalid-feedback">من فضلك أدخل اسمك الحقيقي.</div>
                </div>

                <div class="form-floating mb-3">
                    <input type="email" class="form-control" id="email" name="email" placeholder="name@example.com" required>
                    <label for="email">البريد الإلكتروني</label>
                    <div class="invalid-feedback">من فضلك أدخل بريد إلكتروني صحيح.</div>
                </div>

                <div class="form-floating mb-3">
                    <input type="password" class="form-control" id="password" name="password" placeholder="كلمة المرور" required minlength="6">
                    <label for="password">كلمة المرور</label>
                    <div class="invalid-feedback">كلمة المرور يجب أن لا تقل عن 6 أحرف.</div>
                </div>

                <div class="form-floating mb-4">
                    <select class="form-select" id="grade" name="grade" required>
                        <option value="" selected disabled>اختر سنتك الدراسية</option>
                        <option value="1">الصف الأول الثانوي</option>
                        <option value="2">الصف الثاني الثانوي</option>
                        <option value="3">الصف الثالث الثانوي</option>
                    </select>
                    <label for="grade">السنة الدراسية</label>
                    <div class="invalid-feedback">من فضلك اختر سنتك الدراسية.</div>
                </div>

                <div class="d-grid mb-3">
                    <button type="submit" class="btn btn-primary">إنشاء الحساب الآن 🚀</button>
                </div>

                <div class="text-center mt-3">
                    <span class="text-muted">لديك حساب بالفعل؟</span>
                    <a href="/login" class="text-decoration-none fw-bold">تسجيل الدخول</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    (() => {
        'use strict'
        const forms = document.querySelectorAll('.needs-validation')
        Array.from(forms).forEach(form => {
            form.addEventListener('submit', event => {
                if (!form.checkValidity()) {
                    event.preventDefault()
                    event.stopPropagation()
                }
                form.classList.add('was-validated')
            }, false)
        })
    })()
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>