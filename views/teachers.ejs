<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>منصة مستشارك - قائمة المدرسين</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f8f9fa;
        }
        .custom-border-right {
            border-right: 5px solid #3498db; /* الحافة الزرقاء الديكورية */
        }
    </style>
</head>
<body>
<%- include('partials/navbar') %>
    <div class="container my-5">
        
        <div class="mb-4">
            <a href="/" class="btn btn-outline-secondary btn-sm">⬅️ العودة للصفحة الرئيسية</a>
        </div>

        <h1 class="text-center text-dark fw-bold mb-5">قائمة المدرسين المسجلين في منصة مستشارك 🎓</h1>

        <div class="row justify-content-center">
            
        <% teachers.forEach(teacher => { %>
        <div class="card mb-4 shadow-sm border-0 bg-white p-3">
        <div class="d-flex flex-column flex-md-row align-items-center justify-content-between gap-3">
        
        <div class="d-flex align-items-center gap-3 flex-grow-1">
            <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(teacher.name) %>&background=0d6efd&color=fff&size=80" 
                 class="rounded-circle border" 
                 alt="<%= teacher.name %>" 
                 style="width: 80px; height: 80px; object-fit: cover;">
            
            <div>
                <h4 class="fw-bold text-dark mb-1 fs-5"><%= teacher.name %></h4>
                <span class="badge bg-secondary-subtle text-secondary px-3 py-2 rounded-pill fs-7">
                    📚 <%= teacher.subject %>
                </span>
            </div>
        </div>

        <div class="text-center px-md-4 border-start-md border-end-md flex-shrink-0">
            <div class="text-warning mb-1">
                <span class="fs-4 fw-bold">4.8</span> ★
            </div>
            <small class="text-muted d-block">(متوسط 25 تقييم)</small>
        </div>

        <div class="d-flex gap-2 flex-wrap justify-content-center flex-shrink-0">
            <a href="/teachers/<%= teacher.id %>" class="btn btn-outline-primary btn-sm px-3 py-2 fw-semibold">
                👁️ رؤية تفاصيل التقييمات
            </a>
           
        </div>
        <div class="mt-3 p-2 bg-light rounded border">
    <h6 class="text-secondary mb-2" style="font-size: 0.9rem;">إضافة تقييمك:</h6>
    
    <form action="/teachers/<%= teacher.id %>/review" method="POST">
        
        <div class="mb-2">
            <select name="rating" class="form-select form-select-sm" required>
                <option value="" disabled selected>اختر التقييم (من 1 إلى 5)</option>
                <option value="5">⭐⭐⭐⭐⭐ ممتاز (5)</option>
                <option value="4">⭐⭐⭐⭐ جيد جداً (4)</option>
                <option value="3">⭐⭐⭐ جيد (3)</option>
                <option value="2">⭐⭐ مقبول (2)</option>
                <option value="1">⭐ ضعيف (1)</option>
            </select>
        </div>

        <div class="mb-2">
            <textarea name="review_text" class="form-control form-control-sm" rows="2" placeholder="اكتب رأيك في المدرس هنا (اختياري)..." maxlength="500"></textarea>
        </div>

        <button type="submit" class="btn btn-primary btn-sm w-100">  ✍️ إضافة تقييم </button>
    </form>
</div>

    </div>
</div>
            <% }) %>

        </div>
        
    </div>
<%- include('partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>