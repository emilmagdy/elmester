<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>منصة مستشارك - قائمة المدرسين</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f8f9fa;
        }
        .custom-border-right {
            border-right: 5px solid #3498db; /* الحافة الزرقاء الديكورية */
        }
    </style>
</head>
<body>
<%- include('partials/navbar') %>
    <div class="container my-5">
        
        <div class="mb-4">
            <a href="/" class="btn btn-outline-secondary btn-sm">⬅️ العودة للصفحة الرئيسية</a>
        </div>

        <h1 class="text-center text-dark fw-bold mb-5">قائمة المدرسين المسجلين في منصة مستشارك 🎓</h1>

        <div class="row justify-content-center">
            
            <% teachers.forEach(teacher => { %>
                <div class="col-12 col-md-6 mb-4">
                    
                    <div class="card h-100 shadow-sm p-4 custom-border-right border-0">
                        <div class="card-body p-0">
                            <h3 class="card-title text-primary fw-bold mb-3">الأستاذ / <%= teacher.name %></h3>
                            
                            <p class="card-text text-muted mb-2">
                                <strong class="text-dark">المادة:</strong> 
                                <span class="badge bg-info text-dark fs-6"><%= teacher.subject || 'غير محددة بعد' %></span>
                            </p>
                            
                            <p class="card-text text-secondary small">
                                <strong>الكود الرقمي (ID):</strong> 
                                <span class="text-mono"><%= teacher.id %></span>
                            </p>
                        </div>
                    </div>

                </div>
            <% }) %>

        </div>
        
    </div>
<%- include('partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>