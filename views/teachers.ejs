<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>منصة مستشارك - قائمة المدرسين</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css">

    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f8f9fa;
        }

        .custom-border-right {
            border-right: 5px solid #3498db;
            /* الحافة الزرقاء الديكورية */
        }

        .teacher-card {
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .teacher-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05) !important;
        }

        .teacher-avatar {
            width: 300px;
            height: 300px;
            border: 2px solid #ddd;
            object-fit: cover;
        }

        /* خط فاصل عمودي يظهر فقط في الشاشات الكبيرة وفوق فورم التقييم */
        @media (min-width: 768px) {
            .vertical-divider {
                border-right: 1px solid #dee2e6;
                padding-right: 20px;
            }
        }
    </style>
</head>

<body dir="rtl">
    <%- include('partials/header') %>

        <div class="container my-5">

            <div class="mb-4">
                <a href="/" class="btn btn-outline-secondary btn-sm">⬅️ العودة للصفحة الرئيسية</a>
            </div>
            <div class="container my-4">
                <div
                    class="alert alert-info d-flex justify-content-between align-items-center flex-wrap m-0 shadow-sm border-0">
                    <span class="mb-2 mb-md-0" style="font-family: 'Cairo', sans-serif;">
                        🔍 <strong>مش لاقي المدرس بتاعك؟</strong> ساعدنا نكبر المنصة واقترح المدرس المفضل ليك!
                    </span>
                    <a href="/suggest-teacher" class="btn btn-info text-white fw-bold px-4">اقترح مدرس الآن 💡</a>
                </div>
            </div>
            <h1 class="text-center text-dark fw-bold mb-5">قائمة المدرسين المسجلين في منصة مستشارك 🎓</h1>
            <div class="card mb-4 border-0 shadow-sm bg-grey rounded-0">
                <div class="card-body p-3">
                    <form action="/teachers" method="GET" id="filterForm" class="row g-2 align-items-center">

                        <div class="col-md-5">
                            <label class="form-label small text-secondary fw-bold mb-1">🔍 فلترة بحسب المادة
                                الدراسية:</label>
                            <select name="subject" class="form-select form-select-sm rounded-0"
                                onchange="document.getElementById('filterForm').submit()">
                                <option value="all" <%=selectedSubject==='all' ? 'selected' : '' %>>كل المواد الدراسية
                                </option>
                                <% subjects.forEach(sub=> { %>
                                    <option value="<%= sub %>" <%=selectedSubject===sub ? 'selected' : '' %>><%= sub %>
                                    </option>
                                    <% }) %>
                            </select>
                        </div>

                        <div class="col-md-5">
                            <label class="form-label small text-secondary fw-bold mb-1">📊 ترتيب النتائج بحسب:</label>
                            <select name="sort" class="form-select form-select-sm rounded-0"
                                onchange="document.getElementById('filterForm').submit()">
                                <option value="default" <%=selectedSort==='default' ? 'selected' : '' %>>الترتيب
                                    الافتراضي (الاسم)</option>
                                <option value="rating_desc" <%=selectedSort==='rating_desc' ? 'selected' : '' %>>التقييم
                                    الأعلى أولاً ⭐</option>
                                <option value="rating_asc" <%=selectedSort==='rating_asc' ? 'selected' : '' %>>التقييم
                                    الأقل أولاً</option>
                            </select>
                        </div>

                        <div class="col-md-2 mt-md-4">
                            <a href="/teachers" class="btn btn-outline-secondary btn-sm w-100 rounded-0">إعادة تعيين</a>
                        </div>

                    </form>
                </div>
            </div>
            <div class="row justify-content-center">
                <div class="col-lg-11">

                    <% teachers.forEach(teacher=> { %>
                        <div class="card mb-4 shadow-sm border-0 bg-red p-4 teacher-card custom-border-right">

                            <div class="row align-items-center g-3">

                                <div class="col-md-8">
                                    <div
                                        class="d-flex flex-column flex-sm-row align-items-center justify-content-between gap-3">

                                        <div class="d-flex align-items-center gap-3 flex-grow-1 w-100">
                                            <img src="<%= teacher.photo_url %>" class="teacher-avatar rounded border"
                                                alt="<%= teacher.name %>"
                                                style="width: 80px; height: 80px; object-fit: cover;">

                                            <div>
                                                <h4 class="fw-bold text-dark mb-1 fs-5">
                                                    <%= teacher.name %>
                                                </h4>
                                                <span
                                                    class="badge bg-secondary-subtle text-secondary px-3 py-2 rounded-pill fs-7">
                                                    📚 <%= teacher.subject %>
                                                </span>
                                            </div>
                                        </div>

                                        <div
                                            class="d-flex flex-column align-items-center justify-content-center flex-shrink-0 text-center px-sm-4">
                                            <div class="text-warning mb-1">
                                                <span class="fs-4 fw-bold">
                                                    <%= teacher.avg_rating %>
                                                </span> ★
                                            </div>
                                            <small class="text-muted d-block mb-2">(متوسط <%= teacher.total_reviews %>
                                                    تقييم)</small>
                                            <a href="/teachers/<%= teacher.id %>"
                                                class="btn btn-outline-primary btn-sm px-3 fw-semibold">
                                                👁️ عرض التقييمات
                                            </a>
                                        </div>

                                    </div>
                                </div>

                                <div class="col-md-4 vertical-divider">
                                    <% if (userSession && userSession.userId) { %>
                                        <div class="p-2 bg-light rounded border">
                                            <h6 class="text-secondary mb-2 fw-bold" style="font-size: 0.85rem;">إضافة
                                                تقييمك:</h6>

                                            <form action="/teachers/<%= teacher.id %>/review" method="POST">
                                                <div class="mb-2">
                                                    <select name="rating" class="form-select form-select-sm" required>
                                                        <option value="" disabled selected>اختر التقييم...</option>
                                                        <option value="5">⭐⭐⭐⭐⭐ ممتاز (5)</option>
                                                        <option value="4">⭐⭐⭐⭐ جيد جداً (4)</option>
                                                        <option value="3">⭐⭐⭐ جيد (3)</option>
                                                        <option value="2">⭐⭐ مقبول (2)</option>
                                                        <option value="1">⭐ ضعيف (1)</option>
                                                    </select>
                                                </div>
                                                <div class="mb-2">
                                                    <textarea name="review_text" class="form-control form-control-sm"
                                                        rows="2" placeholder="اكتب رأيك هنا (اختياري)..."
                                                        maxlength="500"></textarea>
                                                </div>
                                                <button type="submit" class="btn btn-primary btn-sm w-100"> ✍️ إرسال
                                                    التقييم </button>
                                            </form>
                                        </div>
                                        <% } else { %>
                                            <div class="text-center py-3">
                                                <p class="text-muted small mb-2">يجب تسجيل الدخول لتتمكن من تقييم
                                                    المدرس.</p>
                                                <a href="/login"
                                                    class="btn btn-sm btn-outline-primary w-100 rounded-0 fw-semibold">🔑
                                                    سجل دخولك الآن</a>
                                            </div>
                                            <% } %>
                                </div>

                            </div>
                        </div>
                        <% }) %>

                </div>
            </div>
        </div> <%- include('partials/footer') %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>