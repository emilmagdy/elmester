    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet">

<style>
    body {
        background-color: #f8f9fa !important;
        font-family: 'Cairo', sans-serif; /* تأكيد استخدام الخط العربي */
    }
    .star-rating {
        color: #ffc107;
        font-size: 1.2rem;
    }
</style>

<body dir="rtl">
<%- include('partials/navbar') %>

<nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm mb-4">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/teachers">منصة تقييم المدرسين</a>
        <a href="/teachers" class="btn btn-outline-light btn-sm">العودة للرئيسية</a>
    </div>
</nav>

<div class="container my-5">
    <div class="card shadow-sm border-0 mb-4 bg-white">
        <div class="card-body d-flex align-items-center p-4">
            <div class="me-4">
                <h1 class="h3 fw-bold text-dark mb-2">تقييمات الأستاذ: <%= teacher.name %></h1>
                <p class="text-muted mb-0">المادة الدراسية: <span class="badge bg-secondary fs-6"><%= teacher.subject %></span></p>
            </div>
        </div>
    </div>

    <h2 class="h4 fw-bold text-secondary mb-4">آراء ومراجعات الطلاب المعتمدة:</h2>

    <% if (reviews.length === 0) { %>
        <div class="alert alert-info text-center py-5 shadow-sm border-0" role="alert">
            <h4 class="alert-heading fw-bold mb-2">لا توجد تقييمات بعد</h4>
            <p class="mb-0 text-muted">هذا المدرس لم يتم نشر أي تقييمات معتمدة له حتى الآن.</p>
        </div>
    <% } else { %>
        <div class="row g-3">
            <% reviews.forEach(function(review) { %>
                <div class="col-12">
                    <div class="card shadow-sm border-0">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <h5 class="fw-bold mb-1 text-primary"><%= review.student_name %></h5>
                                    <small class="text-muted">تم التقييم بنجاح</small>
                                </div>
                                <div class="star-rating">
                                    <% for(let i = 1; i <= 5; i++) { %>
                                        <% if (i <= review.rating) { %>
                                            ★
                                        <% } else { %>
                                            ☆
                                        <% } %>
                                    <% } %>
                                </div>
                            </div>
                            <p class="card-text text-dark fs-5 bg-light p-3 rounded" style="white-space: pre-line;"><%= review.review_text %></p>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } %>
</div>
</body>
<%- include('partials/footer') %>