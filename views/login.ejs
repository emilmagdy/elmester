<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>مستشارك - تسجيل الدخول</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <style>
        body {
            background-color: #f8f9fa;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        .login-container {
            max-width: 450px;
            width: 100%;
            margin: auto;
            padding: 20px;
        }
        .card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
        }
        .btn-primary {
            background-color: #0d6efd;
            border: none;
            border-radius: 8px;
            padding: 12px;
            font-weight: bold;
        }
        .btn-primary:hover {
            background-color: #0b5ed7;
        }
    </style>
</head>
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-JY6XG2MXHM"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-JY6XG2MXHM');
</script>
<body>

    <%- include('partials/header') %>

    <div class="container login-container my-5">
        <div class="card p-4 p-sm-5">
            <div class="text-center mb-4">
                <h2 class="fw-bold text-dark">تسجيل الدخول</h2>
                <p class="text-muted small">مرحباً بك مجدداً في منصة مستشارك التعليمية</p>
            </div>
            <%- include("partials/_messages") %>
            <form action="/login" method="POST" class="needs-validation" novalidate>
                
                <div class="form-floating mb-3">
                    <input type="email" class="form-control" id="floatingEmail" name="email" placeholder="name@example.com" required>
                    <label for="floatingEmail">البريد الإلكتروني</label>
                    <div class="invalid-feedback">برجاء إدخال بريد إلكتروني صحيح.</div>
                </div>

                <div class="form-floating mb-4">
                    <input type="password" class="form-control" id="floatingPassword" name="password" placeholder="Password" required>
                    <label for="floatingPassword">كلمة المرور</label>
                    <div class="invalid-feedback">برجاء إدخال كلمة المرور.</div>
                </div>

                <button class="w-100 btn btn-lg btn-primary mb-3" type="submit">دخول الحساب</button>

                <div class="text-center mt-3">
                    <span class="text-muted small">ليس لديك حساب؟</span>
                    <a href="/register" class="text-decoration-none small fw-bold">إنشاء حساب جديد</a>
                </div>
            </form>
        </div>
    </div>

    <%- include('partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Standard Bootstrap client-side form validation injection logic
        (() => {
            'use strict'
            const forms = document.querySelectorAll('.needs-validation')
            Array.from(forms).forEach(form => {
                form.addEventListener('submit', event => {
                    if (!form.checkValidity()) {
                        event.preventDefault()
                        event.stopPropagation()
                    }
                    form.classList.add('was-validated')
                }, false)
            })
        })()
    </script>
</body>
</html>